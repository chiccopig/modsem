            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Crea una rete di relazioni sociali/agonistiche tra i giocatori presenti nel Knowledge Graph</rdfs:comment>
        <rdfs:label>Identificazione degli Avversari</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoDa"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/p1"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoDa"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/p2"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DifferentIndividualsAtom"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/p1"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/p2"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#avversarioDi"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/p1"/>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/p2"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Identifica automaticamente i tornei che assegnano esattamente 2000 punti, classificandoli nella categoria d&apos;élite Slam</rdfs:comment>
        <rdfs:label>Slam</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/t"/>
                    </rdf:Description>
