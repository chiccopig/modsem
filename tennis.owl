        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/p2">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Permette di inferire la relazione diretta tra un giocatore e il trofeo del torneo partendo dall&apos;esito della finale</rdfs:comment>
        <rdfs:label>Vincitore del Torneo</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Finale"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haVincitore"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#parteDellaCompetizione"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/t"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#vincitoreTorneo"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/t"/>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Assegna una competenza tecnica specifica al giocatore in base allo storico dei suoi successi</rdfs:comment>
        <rdfs:label>Specialista della Terra Battuta</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#vinceIncontro"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoInSuperficie"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/i"/>
                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#TerraBattuta"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#SpecialistaTerra"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Identifica automaticamente i giocatori esperti in base all&apos;anno di nascita</rdfs:comment>
        <rdfs:label>Veterano</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#dataDiNascita"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                        <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#lessThan"/>
                                        <swrl:arguments>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/d"/>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">1990-01-01T00:00:00Z</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </swrl:arguments>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Veterano"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/g"/>
                    </rdf:Description>
