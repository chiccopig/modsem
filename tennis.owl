<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/"
     xml:base="http://www.semanticweb.org/feder/ontologies/2026/1/tennis/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ns="http://www.w3.org/2003/06/sw-vocab-status/ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:wot="http://xmlns.com/wot/0.1/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="https://schema.org/"
     xmlns:tennis="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#"
     xmlns:cpannotationschema="http://www.ontologydesignpatterns.org/schemas/cpannotationschema.owl#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis">
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/collectionentity.owl"/>
        <dc:creator>Federico Chirco</dc:creator>
        <dc:date>2026-01-01</dc:date>
        <dc:description xml:lang="it">Un&apos;ontologia per la modellazione di tornei, incontri, giocatori e risultati nel dominio del tennis professionistico.</dc:description>
        <dc:rights xml:lang="en">Creative Commons Attribution 4.0 International (CC BY 4.0)</dc:rights>
        <dc:title xml:lang="it">Ontologia del Tennis</dc:title>
        <dc:title xml:lang="en">Tennis Ontology</dc:title>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <vann:preferredNamespacePrefix>tennis</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://www.semanticweb.org/feder/ontologies/2026/1/tennis#</vann:preferredNamespaceUri>
        <rdfs:label xml:lang="it">Ontologia del Tennis</rdfs:label>
        <rdfs:label>Tennis Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/rights -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/rights"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ontologydesignpatterns.org/cp/owl/collection.owl#hasMember -->

    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/collection.owl#hasMember"/>
    

<!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haArbitroDiSedia -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haArbitroDiSedia">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#ArbitroDiSedia"/>
    <rdfs:label xml:lang="it">haArbitroDiSedia</rdfs:label>
    <rdfs:comment xml:lang="it">Relazione che collega un incontro di tennis all'arbitro di sedia che lo dirige.</rdfs:comment>
</owl:ObjectProperty>



    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#avversarioDi -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#avversarioDi">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="it">Relazione simmetrica tra due giocatori che si affrontano in un incontro.</rdfs:comment>
        <rdfs:label xml:lang="it">avversarioDi</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocaIncontro -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocaIncontro">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoDa"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:range rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:comment xml:lang="it">Relazione che collega un giocatore all&apos;incontro di tennis a cui partecipa.</rdfs:comment>
        <rdfs:label xml:lang="it">giocaIncontro</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoDa -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoDa">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="it">Relazione inversa di gioca incontro, che collega un incontro ai giocatori che lo disputano.</rdfs:comment>
        <rdfs:label xml:lang="it">giocatoDa</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoInSuperficie -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoInSuperficie">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Superficie"/>
        <rdfs:range>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Cemento"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Erba"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#TerraBattuta"/>
                </owl:oneOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="it">Relazione che associa un incontro alla superficie di gioco su cui viene disputato, come erba, cemento o terra battuta.</rdfs:comment>
        <rdfs:label xml:lang="it">giocatoInSuperficie</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haGiocatoA -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haGiocatoA">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Città"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Località"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#partecipaA"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#siSvolgeA"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Relazione derivata tramite property chain che collega un giocatore alla città in cui ha giocato, a partire dal torneo a cui partecipa e dal luogo in cui il torneo si svolge.</rdfs:comment>
        <rdfs:label xml:lang="it">haGiocatoA</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haIncontro -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haIncontro">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#parteDellaCompetizione"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:range rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:comment xml:lang="it">Relazione che collega un torneo agli incontri che fanno parte della competizione.</rdfs:comment>
        <rdfs:label xml:lang="it">haIncontro</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haPartecipante -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haPartecipante">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#partecipaA"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="it">Relazione che collega un torneo ai giocatori che vi partecipano.</rdfs:comment>
        <rdfs:label xml:lang="it">haPartecipante</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haTabellone -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haTabellone">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Tabellone"/>
        <rdfs:comment xml:lang="it">Relazione che associa un torneo al relativo tabellone competitivo.</rdfs:comment>
        <rdfs:label xml:lang="it">haTabellone</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haVincitore -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haVincitore">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#giocatoDa"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="it">Relazione funzionale che collega un incontro al giocatore che lo ha vinto.</rdfs:comment>
        <rdfs:label xml:lang="it">haVincitore</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#includeIncontro -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#includeIncontro">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/collection.owl#hasMember"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Tabellone"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:comment xml:lang="it">Relazione che collega un tabellone agli incontri che ne fanno parte.</rdfs:comment>
        <rdfs:label xml:lang="it">includeIncontro</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#incontroSuccessivo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#incontroSuccessivo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:range rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:comment xml:lang="it">Relazione transitiva che collega un incontro a uno o più incontri successivi nel percorso del tabellone.</rdfs:comment>
        <rdfs:label xml:lang="it">incontroSuccessivo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#parteDellaCompetizione -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#parteDellaCompetizione">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:range rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:comment xml:lang="it">Relazione che collega un incontro al torneo o alla competizione di cui fa parte.</rdfs:comment>
        <rdfs:label xml:lang="it">parteDellaCompetizione</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#partecipaA -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#partecipaA">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:range rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:comment xml:lang="it">Relazione che collega un giocatore al torneo a cui prende parte.</rdfs:comment>
        <rdfs:label xml:lang="it">partecipaA</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#siSvolgeA -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#siSvolgeA">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Città"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Località"/>
        <rdfs:comment xml:lang="it">Relazione che collega un torneo alla città o località in cui si svolge.</rdfs:comment>
        <rdfs:label xml:lang="it">siSvolgeA</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#vinceIncontro -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#vinceIncontro">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Incontro"/>
        <rdfs:range rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:comment xml:lang="it">Relazione che collega un giocatore all&apos;incontro che ha vinto.</rdfs:comment>
        <rdfs:label xml:lang="it">vinceIncontro</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#vincitoreTorneo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#vincitoreTorneo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="it">Relazione che collega un torneo al suo vincitore finale.</rdfs:comment>
        <rdfs:label xml:lang="it">vincitoreTorneo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#dataDiNascita -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#dataDiNascita">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="it">Proprietà che indica la data di nascita di un giocatore.</rdfs:comment>
        <rdfs:label xml:lang="it">data di nascita</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haDataInizio -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#haDataInizio">
        <rdfs:domain rdf:resource="https://schema.org/SportsEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="it">Proprietà che indica la data di inizio di un evento sportivo, come un torneo o un incontro di tennis.</rdfs:comment>
        <rdfs:label xml:lang="it">ha data inizio</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#montepremi -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#montepremi">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Torneo"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Proprietà che rappresenta il valore economico complessivo del montepremi associato a un torneo.</rdfs:comment>
        <rdfs:label xml:lang="it">montepremi</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#puntiATP -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#puntiATP">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Proprietà che indica il numero di punti ATP associati a un giocatore nel ranking professionistico maschile.</rdfs:comment>
        <rdfs:label xml:lang="it">punti ATP</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#ArbitroDiSedia -->

    <owl:Class rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#ArbitroDiSedia">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="it">Persona che dirige un incontro di tennis dal seggiolone arbitrale.</rdfs:comment>
        <rdfs:label xml:lang="it">ArbitroDiSedia</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Campione -->

    <owl:Class rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Campione">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#Giocatore"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/feder/ontologies/2026/1/tennis#vinceIncontro"/>
